ame"},"components":[{"type":"textnode","content":"First name"}]},{"type":"input","name":"First Name Input","void":true,"classes":["addon-input"],"attributes":{"type":"text","id":"register-first-name","placeholder":"First name"}}]},{"name":"Input Field","classes":["addon-field"],"attributes":{"id":"iqroha"},"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"register-last-name"},"components":[{"type":"textnode","content":"Last name"}]},{"type":"input","name":"Last Name Input","void":true,"classes":["addon-input"],"attributes":{"type":"text","id":"register-last-name","placeholder":"Last name"}}]}]},{"name":"Input Field","classes":["addon-field"],"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"register-email"},"components":[{"type":"textnode","content":"Email address"}]},{"type":"input","name":"Register Email Input","void":true,"classes":["addon-input"],"attributes":{"type":"email","id":"register-email","placeholder":"name@email.com"}}]},{"name":"Input Row","classes":["auth-row"],"components":[{"name":"Input Field","classes":["addon-field"],"attributes":{"id":"i427q6"},"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"register-password"},"components":[{"type":"textnode","content":"Password"}]},{"type":"input","name":"Register Password Input","void":true,"classes":["addon-input"],"attributes":{"type":"password","id":"register-password","placeholder":"Create a password"}}]},{"name":"Input Field","classes":["addon-field"],"attributes":{"id":"iwt4eh"},"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"register-phone"},"components":[{"type":"textnode","content":"Phone number"}]},{"type":"input","name":"Phone Input","void":true,"classes":["addon-input"],"attributes":{"type":"tel","id":"register-phone","placeholder":"(123) 456-7890"}}]}]},{"type":"label","name":"Checkbox Row","classes":["auth-check"],"components":[{"type":"checkbox","name":"Consent Checkbox","void":true,"attributes":{"type":"checkbox"}},{"tagName":"span","type":"text","name":"Checkbox Text","components":[{"type":"textnode","content":"I agree to receive service updates, appointment messages, and account-related communication."}]}]},{"type":"button","name":"Submit Button","classes":["addon-btn","auth-submit"],"attributes":{"type":"submit"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Create my account"}]}]},{"name":"Helper Text","classes":["auth-helper"],"components":[{"type":"textnode","content":"Already have an account? "},{"type":"button","name":"Switch To Login","attributes":{"type":"button","data-js":"switch-login"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Log in instead"}]}]}]}]}]}]}]}]}]},{"type":"script","attributes":{"data-scope":"quota-calculator"},"components":[{"type":"textnode","content":"\n(function () {\n  var root = document.querySelector('[data-js=\"quota-calculator\"]');\n  if (!root) return;\n\n  var sizeInput = root.querySelector('[data-js=\"size\"]');\n  var typeSelect = root.querySelector('[data-js=\"type\"]');\n  var frequencyInputs = root.querySelectorAll('[data-js=\"frequency\"]');\n  var priceEl = root.querySelector('[data-js=\"price\"]');\n  var summaryEl = root.querySelector('[data-js=\"summary\"]');\n  var hoursEl = root.querySelector('[data-js=\"hours\"]');\n  var crewEl = root.querySelector('[data-js=\"crew\"]');\n  var timelineEl = root.querySelector('[data-js=\"timeline\"]');\n\n  var typeConfig = {\n    patio: { label: 'Patio / compact garden', base: 180, rate: 4.5, crew: 1 },\n    family: { label: 'Family garden', base: 300, rate: 7.5, crew: 2 },\n    ornamental: { label: 'Ornamental landscape', base: 520, rate: 9.5, crew: 2 },\n    estate: { label: 'Large estate garden', base: 950, rate: 11.5, crew: 3 },\n    commercial: { label: 'Commercial outdoor area', base: 1200, rate: 13.5, crew: 4 }\n  };\n\n  var frequencyConfig = {\n    'one-time': { label: 'one-time project', multiplier: 1, hoursFactor: 1 },\n    monthly: { label: 'monthly care', multiplier: 0.72, hoursFactor: 0.7 },\n    weekly: { label: 'weekly care', multiplier: 0.46, hoursFactor: 0.5 }\n  };\n\n  function getFrequency() {\n    var active = 'one-time';\n    frequencyInputs.forEach(function (item) {\n      if (item.checked) active = item.value;\n    });\n    return active;\n  }\n\n  function formatPrice(value) {\n    return '$' + Math.round(value).toLocaleString();\n  }\n\n  function updateQuota() {\n    var size = parseFloat(sizeInput.value || 0);\n    if (!size || size < 10) size = 10;\n\n    var type = typeConfig[typeSelect.value] || typeConfig.family;\n    var frequency = frequencyConfig[getFrequency()] || frequencyConfig['one-time'];\n\n    var estimated = (type.base + (size * type.rate)) * frequency.multiplier;\n    var hours = Math.max(4, Math.round((size / 10) * frequency.hoursFactor));\n    var crew = type.crew + (size > 300 ? 1 : 0);\n    var days = Math.max(1, Math.ceil(hours / 8));\n\n    priceEl.textContent = formatPrice(estimated);\n    summaryEl.textContent = type.label + ' · ' + Math.round(size) + ' m˛ · ' + frequency.label;\n    hoursEl.textContent = hours + ' hrs';\n    crewEl.textContent = crew + (crew > 1 ? ' pros' : ' pro');\n    timelineEl.textContent = days + (days > 1 ? ' days' : ' day');\n  }\n\n  sizeInput.addEventListener('input', updateQuota);\n  typeSelect.addEventListener('change', updateQuota);\n  frequencyInputs.forEach(function (item) {\n    item.addEventListener('change', updateQuota);\n  });\n\n  updateQuota();\n})();\n"}]},{"type":"script","attributes":{"data-scope":"auth-switcher"},"components":[{"type":"textnode","content":"\n(function () {\n  var root = document.querySelector('[data-js=\"auth-switcher\"]');\n  if (!root) return;\n\n  var loginBtn = root.querySelector('[data-js=\"show-login\"]');\n  var registerBtn = root.querySelector('[data-js=\"show-register\"]');\n  var loginForm = root.querySelector('[data-js=\"login-form\"]');\n  var registerForm = root.querySelector('[data-js=\"register-form\"]');\n  var switchLogin = root.querySelector('[data-js=\"switch-login\"]');\n  var switchRegister = root.querySelector('[data-js=\"switch-register\"]');\n\n  function showLogin() {\n    loginBtn.classList.add('is-active');\n    registerBtn.classList.remove('is-active');\n    loginForm.classList.add('is-active');\n    registerForm.classList.remove('is-active');\n  }\n\n  function showRegister() {\n    registerBtn.classList.add('is-active');\n    loginBtn.classList.remove('is-active');\n    registerForm.classList.add('is-active');\n    loginForm.classList.remove('is-active');\n  }\n\n  loginBtn.addEventListener('click', showLogin);\n  registerBtn.addEventListener('click', showRegister);\n  switchLogin.addEventListener('click', showLogin);\n  switchRegister.addEventListener('click', showRegister);\n})();\n"}]},{"type":"section","classes":["gjs-section"],"attributes":{"id":"i0ms79"},"components":[{"type":"container","classes":["gjs-container"],"attributes":{},"components":[{"type":"flex-row","classes":["gjs-plg-flex-row"],"attributes":{"data-type-role":"flex-row","id":"iof8d7"},"components":[{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"inpvei"},"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"id":"idawqg","src":"https://cdn.grapesjs.com/workspaces/cmc4xkttt0df99wj7woejj4g8/assets/7f031531-842c-4af1-9850-7b788bba0b32__open-garden-1.webp"}}]},{"type":"flex-column","classes":["gjs-plg-flex-column"],"attributes":{"data-type-role":"flex-column","id":"iaky2j"},"components":[{"type":"accordion-group","attributes":{"data-type-role":"accordion-group","id":"i68c0g"},"components":[{"type":"accordion","classes":["gjs-plg-accordion"],"attributes":{"data-type-role":"accordion","open":true,"id":"ifldrp"},"components":[{"type":"