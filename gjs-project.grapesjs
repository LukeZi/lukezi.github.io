vice"}]}]},{"type":"link","name":"Utility Link","classes":["auth-link"],"attributes":{"href":"page://6qS5emjMRX4KTgvo"},"components":[{"type":"textnode","content":"Forgot password?"}]}]},{"type":"button","name":"Submit Button","classes":["addon-btn","auth-submit"],"attributes":{"type":"submit"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Log in to my account"}]}]},{"name":"Form Helper","classes":["auth-helper"],"components":[{"type":"textnode","content":"New here? "},{"type":"button","name":"Switch Button","attributes":{"type":"button","data-js":"switch-register"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Create your account"}]}]}]}]},{"type":"form","name":"Register Form","classes":["auth-form"],"attributes":{"method":"get","data-js":"register-form"},"components":[{"tagName":"h2","type":"heading","name":"Form Title","classes":["gjs-t-h2","addon-block-title"],"components":[{"type":"textnode","content":"Create your account"}]},{"tagName":"span","type":"text","name":"Form Subtitle","classes":["addon-block-sub"],"components":[{"type":"textnode","content":"Register once to speed up quotations, save addresses, and manage repeat garden care."}]},{"name":"Field Row","classes":["auth-row"],"components":[{"name":"Field Group","classes":["addon-field"],"components":[{"type":"label","name":"Field Label","classes":["addon-label"],"attributes":{"for":"register-first-name-new"},"components":[{"type":"textnode","content":"First name"}]},{"type":"input","name":"Text Input","void":true,"classes":["addon-input"],"attributes":{"type":"text","id":"register-first-name-new","placeholder":"First name"}}]},{"name":"Field Group","classes":["addon-field"],"components":[{"type":"label","name":"Field Label","classes":["addon-label"],"attributes":{"for":"register-last-name-new"},"components":[{"type":"textnode","content":"Last name"}]},{"type":"input","name":"Text Input","void":true,"classes":["addon-input"],"attributes":{"type":"text","id":"register-last-name-new","placeholder":"Last name"}}]}]},{"name":"Field Group","classes":["addon-field"],"components":[{"type":"label","name":"Field Label","classes":["addon-label"],"attributes":{"for":"register-email-new"},"components":[{"type":"textnode","content":"Email address"}]},{"type":"input","name":"Email Input","void":true,"classes":["addon-input"],"attributes":{"type":"email","id":"register-email-new","placeholder":"name@email.com"}}]},{"name":"Field Row","classes":["auth-row"],"components":[{"name":"Field Group","classes":["addon-field"],"components":[{"type":"label","name":"Field Label","classes":["addon-label"],"attributes":{"for":"register-password-new"},"components":[{"type":"textnode","content":"Password"}]},{"type":"input","name":"Password Input","void":true,"classes":["addon-input"],"attributes":{"type":"password","id":"register-password-new","placeholder":"Create a password"}}]},{"name":"Field Group","classes":["addon-field"],"components":[{"type":"label","name":"Field Label","classes":["addon-label"],"attributes":{"for":"register-phone-new"},"components":[{"type":"textnode","content":"Phone number"}]},{"type":"input","name":"Phone Input","void":true,"classes":["addon-input"],"attributes":{"type":"tel","id":"register-phone-new","placeholder":"(123) 456-7890"}}]}]},{"type":"label","name":"Checkbox Field","classes":["auth-check"],"components":[{"type":"checkbox","name":"Checkbox Input","void":true,"attributes":{"type":"checkbox"}},{"tagName":"span","type":"text","name":"Checkbox Label","components":[{"type":"textnode","content":"I agree to receive service updates, appointment messages, and account-related communication."}]}]},{"type":"button","name":"Submit Button","classes":["addon-btn","auth-submit"],"attributes":{"type":"submit"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Create my account"}]}]},{"name":"Form Helper","classes":["auth-helper"],"components":[{"type":"textnode","content":"Already have an account? "},{"type":"button","name":"Switch Button","attributes":{"type":"button","data-js":"switch-login"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Log in instead"}]}]}]}]}]}]}]}]}]},{"type":"script","attributes":{"data-scope":"quota-estimator"},"components":[{"type":"textnode","content":"\n(function () {\n  var root = document.querySelector('[data-js=\"quota-estimator\"]');\n  if (!root) return;\n\n  var sizeInput = root.querySelector('[data-js=\"size\"]');\n  var typeSelect = root.querySelector('[data-js=\"type\"]');\n  var frequencyInputs = root.querySelectorAll('[data-js=\"frequency\"]');\n  var priceEl = root.querySelector('[data-js=\"price\"]');\n  var summaryEl = root.querySelector('[data-js=\"summary\"]');\n  var hoursEl = root.querySelector('[data-js=\"hours\"]');\n  var crewEl = root.querySelector('[data-js=\"crew\"]');\n  var timelineEl = root.querySelector('[data-js=\"timeline\"]');\n\n  var typeConfig = {\n    patio: { label: 'Patio / compact garden', base: 180, rate: 4.5, crew: 1 },\n    family: { label: 'Family garden', base: 300, rate: 7.5, crew: 2 },\n    ornamental: { label: 'Ornamental landscape', base: 520, rate: 9.5, crew: 2 },\n    estate: { label: 'Large estate garden', base: 950, rate: 11.5, crew: 3 },\n    commercial: { label: 'Commercial outdoor area', base: 1200, rate: 13.5, crew: 4 }\n  };\n\n  var frequencyConfig = {\n    'one-time': { label: 'one-time project', multiplier: 1, hoursFactor: 1 },\n    monthly: { label: 'monthly care', multiplier: 0.72, hoursFactor: 0.7 },\n    weekly: { label: 'weekly care', multiplier: 0.46, hoursFactor: 0.5 }\n  };\n\n  function getFrequency() {\n    var active = 'one-time';\n    frequencyInputs.forEach(function (item) {\n      if (item.checked) active = item.value;\n    });\n    return active;\n  }\n\n  function formatPrice(value) {\n    return '$' + Math.round(value).toLocaleString();\n  }\n\n  function updateQuota() {\n    var size = parseFloat(sizeInput.value || 0);\n    if (!size || size < 10) size = 10;\n\n    var type = typeConfig[typeSelect.value] || typeConfig.family;\n    var frequency = frequencyConfig[getFrequency()] || frequencyConfig['one-time'];\n\n    var estimated = (type.base + (size * type.rate)) * frequency.multiplier;\n    var hours = Math.max(4, Math.round((size / 10) * frequency.hoursFactor));\n    var crew = type.crew + (size > 300 ? 1 : 0);\n    var days = Math.max(1, Math.ceil(hours / 8));\n\n    priceEl.textContent = formatPrice(estimated);\n    summaryEl.textContent = type.label + ' · ' + Math.round(size) + ' m˛ · ' + frequency.label;\n    hoursEl.textContent = hours + ' hrs';\n    crewEl.textContent = crew + (crew > 1 ? ' pros' : ' pro');\n    timelineEl.textContent = days + (days > 1 ? ' days' : ' day');\n  }\n\n  sizeInput.addEventListener('input', updateQuota);\n  typeSelect.addEventListener('change', updateQuota);\n  frequencyInputs.forEach(function (item) {\n    item.addEventListener('change', updateQuota);\n  });\n\n  updateQuota();\n})();\n"}]},{"type":"script","attributes":{"data-scope":"auth-switcher-new"},"components":[{"type":"textnode","content":"\n(function () {\n  var root = document.querySelector('[data-js=\"auth-switcher-new\"]');\n  if (!root) return;\n\n  var loginBtn = root.querySelector('[data-js=\"show-login\"]');\n  var registerBtn = root.querySelector('[data-js=\"show-register\"]');\n  var loginForm = root.querySelector('[data-js=\"login-form\"]');\n  var registerForm = root.querySelector('[data-js=\"register-form\"]');\n  var switchLogin = root.querySelector('[data-js=\"switch-login\"]');\n  var switchRegister = root.querySelector('[data-js=\"switch-register\"]');\n\n  function showLogin() {\n    loginBtn.classList.add('is-active');\n    registerBtn.classList.remove('is-active');\n    loginForm.classList.add('is-active');\n    registerForm.classList.remove('is-active');\n  }\n\n  function showRegister() {\n    registerBtn.classList.add('is-active');\n    loginBtn.classList.remove('is-active');\n    registerForm.classList.add('is-active');\n    loginForm.classList.remove('is-active');\n  }\n\n  loginBtn.addEventListener('click', showLogin);\n  registerBtn.addEventListener('click', showRegister);\n  switchLogin.addEventListener('click', showLogin);\n  switchRegister.addEventListener('click', showRegister);\n})();\n"}]},{"type":"section","name":"Garden Quota Section","classes":["gjs-section","addon-section","addon-shell","addon-bg"],"attributes":{"id":"inefzq"},"components":[{"type":"container","name":"Garden Quota Container","classes":["gjs-container"],"attributes":{},"components":[{"name":"Section Heading","classes":["addon-head"],"components":[{"tagName":"span","type":"text","name":"Section Kicker","classes":["addon-kicker"],"components":[{"type":"textnode","content":"Garden configurator"}]},{"type":"heading","name":"Section Title","classes":["gjs-t-h1","addon-title"],"components":[{"type":"textnode","content":"Configure your garden service and receive an instant estimated quota"}]},{"tagName":"span","type":"text","name":"Section Description","classes":["addon-text"],"components":[{"type":"textnode","content":"Choose your garden type, enter the approximate size, and get a realistic starting estimate for planning, planting, and recurring care. This is perfect for homeowners who want a fast number before booking a consultation."}]}]},{"name":"Configurator Grid","classes":["addon-grid"],"attributes":{"data-js":"quota-calculator"},"components":[{"name":"Configurator Column","classes":["addon-col"],"components":[{"name":"Configurator Card","classes":["addon-card"],"components":[{"tagName":"h2","type":"heading","name":"Configurator Title","classes":["gjs-t-h2","addon-block-title"],"components":[{"type":"textnode","content":"Garden quota estimator"}]},{"tagName":"span","type":"text","name":"Configurator Subtitle","classes":["addon-block-sub"],"components":[{"type":"textnode","content":"Adjust the details below to preview a personalized service range."}]},{"name":"Input Field","classes":["addon-field"],"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"garden-size-input"},"components":[{"type":"textnode","content":"Garden size"}]},{"type":"input","name":"Garden Size Input","void":true,"classes":["addon-input"],"attributes":{"type":"number","data-js":"size","id":"garden-size-input","min":"10","step":"10","value":"120","placeholder":"Enter square meters"}}]},{"name":"Input Field","classes":["addon-field"],"components":[{"type":"label","name":"Input Label","classes":["addon-label"],"attributes":{"for":"garden-type-select"},"components":[{"type":"textnode","content":"Garden type"}]},{"type":"select","name":"Garden Type Select","classes":["addon-select"],"attributes":{"type":"text","data-js":"type","id":"garden-type-select","aria-label":"Garden type"},"components":[{"type":"option","attributes":{"value":"patio"},"components":[{"type":"textnode","content":"Patio / compact garden"}]},{"type":"option","attributes":{"value":"family","selected":true},"components":[{"type":"textnode","content":"Family garden"}]},{"type":"option","attributes":{"value":"ornamental"},"components":[{"type":"textnode","content":"Ornamental landscape"}]},{"type":"option","attributes":{"value":"estate"},"components":[{"type":"textnode","content":"Large estate garden"}]},{"type":"option","attributes":{"value":"commercial"},"components":[{"type":"textnode","content":"Commercial outdoor area"}]}]}]},{"name":"Visit Frequency Group","classes":["addon-field"],"components":[{"tagName":"span","type":"text","name":"Input Label","classes":["addon-label"],"components":[{"type":"textnode","content":"Preferred maintenance frequency"}]},{"name":"Choice Row","classes":["addon-choice-row"],"components":[{"type":"label","name":"Choice Option","classes":["addon-choice"],"components":[{"type":"radio","void":true,"attributes":{"type":"radio","name":"quota-frequency","value":"one-time","data-js":"frequency","checked":true}},{"tagName":"span","type":"text","name":"Choice Label","components":[{"type":"textnode","content":"One-time project"}]}]},{"type":"label","name":"Choice Option","classes":["addon-choice"],"components":[{"type":"radio","void":true,"attributes":{"type":"radio","name":"quota-frequency","value":"monthly","data-js":"frequency"}},{"tagName":"span","type":"text","name":"Choice Label","components":[{"type":"textnode","content":"Monthly care"}]}]},{"type":"label","name":"Choice Option","classes":["addon-choice"],"components":[{"type":"radio","void":true,"attributes":{"type":"radio","name":"quota-frequency","value":"weekly","data-js":"frequency"}},{"tagName":"span","type":"text","name":"Choice Label","components":[{"type":"textnode","content":"Weekly care"}]}]}]}]},{"name":"Result Card","classes":["addon-result"],"components":[{"name":"Result Header","classes":["addon-result-top"],"components":[{"name":"Result Summary","components":[{"tagName":"span","type":"text","name":"Result Label","classes":["addon-result-label"],"components":[{"type":"textnode","content":"Estimated starting quota"}]},{"tagName":"strong","type":"text","name":"Result Price","classes":["addon-result-price"],"attributes":{"data-js":"price"},"components":[{"type":"textnode","content":"$1,350"}]}]},{"tagName":"span","type":"text","name":"Result Note","classes":["addon-result-note"],"attributes":{"data-js":"summary"},"components":[{"type":"textnode","content":"Family garden · 120 m˛ · one-time project"}]}]},{"tagName":"span","type":"text","name":"Result Description","classes":["addon-result-note"],"components":[{"type":"textnode","content":"This estimate includes planning, labor, standard materials allocation, and a recommended care setup based on the parameters selected."}]},{"name":"Result Stats","classes":["addon-stats"],"components":[{"name":"Result Stat","classes":["addon-stat"],"components":[{"tagName":"strong","type":"text","name":"Stat Value","attributes":{"data-js":"hours"},"components":[{"type":"textnode","content":"12 hrs"}]},{"tagName":"span","type":"text","name":"Stat Label","components":[{"type":"textnode","content":"Estimated labor"}]}]},{"name":"Result Stat","classes":["addon-stat"],"components":[{"tagName":"strong","type":"text","name":"Stat Value","attributes":{"data-js":"crew"},"components":[{"type":"textnode","content":"2 pros"}]},{"tagName":"span","type":"text","name":"Stat Label","components":[{"type":"textnode","content":"Recommended crew"}]}]},{"name":"Result Stat","classes":["addon-stat"],"components":[{"tagName":"strong","type":"text","name":"Stat Value","attributes":{"data-js":"timeline"},"components":[{"type":"textnode","content":"2 days"}]},{"tagName":"span","type":"text","name":"Stat Label","components":[{"type":"textnode","content":"Expected timeline"}]}]}]}]},{"name":"Action Row","classes":["addon-actions"],"components":[{"type":"link","name":"Primary Action","classes":["addon-btn"],"attributes":{"href":"/"},"components":[{"type":"textnode","content":"Get my detailed quote"}]},{"type":"link","name":"Secondary Action","classes":["addon-btn","alt"],"attributes":{"href":"#iyhen"},"components":[{"type":"textnode","content":"Talk to an expert"}]}]}]}]},{"name":"Info Column","classes":["addon-col"],"components":[{"name":"Info Card","classes":["addon-card","addon-card-soft"],"components":[{"tagName":"h2","type":"heading","name":"Info Title","classes":["gjs-t-h2","addon-block-title"],"components":[{"type":"textnode","content":"How the quota is calculated"}]},{"tagName":"span","type":"text","name":"Info Subtitle","classes":["addon-block-sub"],"components":[{"type":"textnode","content":"We use a simple planning model that mirrors how professional landscape teams scope a new job."}]},{"name":"Feature List","classes":["addon-list"],"components":[{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","src":"https://api.iconify.design/lucide-ruler.svg?color=%2325A452","alt":"Size icon"}}]},{"name":"Feature Copy","classes":["addon-item-copy"],"components":[{"tagName":"strong","type":"text","name":"Feature Title","components":[{"type":"textnode","content":"Size-based workload"}]},{"tagName":"span","type":"text","name":"Feature Text","components":[{"type":"textnode","content":"The larger the area, the more prep, cleanup, planting, edging, and finishing work is needed."}]}]}]},{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","src":"https://api.iconify.design/lucide-trees.svg?color=%2325A452","alt":"Garden type icon"}}]},{"name":"Feature Copy","classes":["addon-item-copy"],"components":[{"tagName":"strong","type":"text","name":"Feature Title","components":[{"type":"textnode","content":"Garden type complexity"}]},{"tagName":"span","type":"text","name":"Feature Text","components":[{"type":"textnode","content":"Patio gardens are usually lighter, while ornamental or commercial landscapes require more detailed care and materials."}]}]}]},{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","src":"https://api.iconify.design/lucide-calendar-days.svg?color=%2325A452","alt":"Schedule icon"}}]},{"name":"Feature Copy","classes":["addon-item-copy"],"components":[{"tagName":"strong","type":"text","name":"Feature Title","components":[{"type":"textnode","content":"Service frequency"}]},{"tagName":"span","type":"text","name":"Feature Text","components":[{"type":"textnode","content":"One-time projects usually include setup and transformation work, while recurring plans are optimized for routine maintenance."}]}]}]},{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","src":"https://api.iconify.design/lucide-shield-check.svg?color=%2325A452","alt":"Protection icon"}}]},{"name":"Feature Copy","classes":["addon-item-copy"],"components":[{"tagName":"strong","type":"text","name":"Feature Title","components":[{"type":"textnode","content":"Transparent planning range"}]},{"tagName":"span","type":"text","name":"Feature Text","components":[{"type":"textnode","content":"Your instant estimate is meant to help you budget early before a more exact site visit and final proposal."}]}]}]}]},{"name":"Info Note Box","classes":["addon-note-box"],"components":[{"tagName":"strong","type":"text","name":"Note Title","components":[{"type":"textnode","content":"Need a more accurate price?"}]},{"tagName":"span","type":"text","name":"Note Text","components":[{"type":"textnode","content":"Upload photos, share your location, and describe goals like turf repair, seasonal planting, irrigation, pruning, or full redesign. Our team can prepare a more refined proposal after a quick review."}]}]}]}]}]}]}]},{"type":"section","name":"Login Register Section","classes":["gjs-section","addon-section","addon-shell"],"attributes":{},"components":[{"type":"container","name":"Login Register Container","classes":["gjs-container"],"attributes":{},"components":[{"name":"Section Heading","classes":["addon-head"],"components":[{"tagName":"span","type":"text","name":"Section Kicker","classes":["addon-kicker"],"components":[{"type":"textnode","content":"Customer access"}]},{"type":"heading","name":"Section Title","classes":["gjs-t-h1","addon-title"],"components":[{"type":"textnode","content":"Log in to manage your bookings or create a new account in minutes"}]},{"tagName":"span","type":"text","name":"Section Description","classes":["addon-text"],"components":[{"type":"textnode","content":"Returning customers can track appointments, update property details, and review quotations. New customers can register to save preferences and make future requests faster."}]}]},{"name":"Auth Wrap","classes":["auth-wrap"],"attributes":{"data-js":"auth-switcher"},"components":[{"name":"Auth Intro Panel","classes":["auth-panel"],"components":[{"name":"Auth Intro Card","classes":["auth-card","auth-intro"],"components":[{"tagName":"span","type":"text","name":"Section Kicker","classes":["addon-kicker"],"components":[{"type":"textnode","content":"Why create an account"}]},{"tagName":"h2","type":"heading","name":"Intro Title","classes":["gjs-t-h2","addon-block-title"],"attributes":{"id":"iyavrt"},"components":[{"type":"textnode","content":"Everything you need for garden service in one place"}]},{"tagName":"span","type":"text","name":"Intro Text","classes":["addon-block-sub"],"components":[{"type":"textnode","content":"A personal account gives you a smoother way to request maintenance, compare estimates, and stay connected with your service team across the season."}]},{"name":"Feature List","classes":["addon-list"],"components":[{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","src":"https://api.iconify.design/lucide-clipboard-list.svg?color=%2325A452","alt":"Bookings icon"}}]},{"name":"Feature Copy","classes":["addon-item-copy"],"components":[{"tagName":"strong","type":"text","name":"Feature Title","components":[{"type":"textnode","content":"See your upcoming bookings"}]},{"tagName":"span","type":"text","name":"Feature Text","components":[{"type":"textnode","content":"Keep your visits, estimates, and request history organized in a single dashboard."}]}]}]},{"name":"Feature Item","classes":["addon-item"],"components":[{"name":"Feature Icon","classes":["addon-icon"],"components":[{"type":"image","resizable":{"ratioDefault":1},"attributes":{"loading":"lazy","